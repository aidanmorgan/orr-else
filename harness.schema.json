{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["settings", "scheduler", "states"],
  "additionalProperties": false,
  "definitions": {
    "toolProfileShape": {
      "type": "object",
      "description": "Reusable partial command-tool configuration. Fields here are applied as defaults before per-tool values. Per-tool fields always win.",
      "additionalProperties": false,
      "properties": {
        "env": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "cwd": { "type": "string" },
        "allowCwdOverride": { "type": "boolean" },
        "timeoutMs": { "type": "integer", "minimum": 1 },
        "wrapperTimeoutMs": { "type": "integer", "minimum": 1 },
        "argsMode": { "type": "string", "enum": ["replace", "append"] },
        "allowArgs": { "type": "boolean" },
        "acceptMaxBuffer": { "type": "boolean" },
        "successExitCodes": {
          "type": "array",
          "items": { "type": "integer", "minimum": 0 },
          "minItems": 1,
          "uniqueItems": true
        },
        "argumentPathScope": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "root": { "type": "string" },
            "rootKind": { "type": "string" },
            "workspaceRoot": { "type": "string" },
            "virtualRoots": { "type": "array", "items": { "type": "string" } },
            "mustStayInsideRoot": { "type": "boolean" },
            "positionals": { "type": "boolean" },
            "flags": { "type": "array", "items": { "type": "string" } }
          }
        },
        "failureLimit": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "maxFailuresPerState": { "type": "integer", "minimum": 1 },
            "suggestedOutcome": { "type": "string" },
            "suggestedOutcomeByState": {
              "type": "object",
              "additionalProperties": { "type": "string" }
            },
            "suggestedOutcomeByAction": {
              "type": "object",
              "additionalProperties": { "type": "string" }
            },
            "message": { "type": "string" },
            "terminal": { "type": "boolean" }
          }
        }
      }
    }
  },
  "properties": {
    "settings": {
      "type": "object",
      "required": ["maxConcurrentSlots", "handoverTemplate", "defaultModel", "startState"],
      "properties": {
        "maxConcurrentSlots": { "type": "integer", "minimum": 1 },
        "handoverTemplate": { "type": "string" },
        "agentTurnTimeoutMs": { "type": "integer" },
        "processReapIntervalMs": { "type": "integer" },
        "teamLeadSystemPrompt": { "type": "string" },
        "projectObjective": { "type": "string" },
        "startState": { "type": "string" },
        "workflowVersion": { "type": "string" },
        "harnessRestartEvent": { "type": "string" },
        "harnessRestartPrompt": { "type": "string" },
        "contextRestartEvent": { "type": "string" },
        "contextRestartPrompt": { "type": "string" },
        "compatibilityMode": { "type": "string" },
        "compatibility": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "modes": {
              "type": "object",
              "additionalProperties": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "masterRules": { "type": "array", "items": { "type": "string" } },
                  "ruleDirs": { "type": "array", "items": { "type": "string" } },
                  "hookDirs": { "type": "array", "items": { "type": "string" } },
                  "docsDirs": { "type": "array", "items": { "type": "string" } },
                  "agentDirs": { "type": "array", "items": { "type": "string" } }
                }
              }
            }
          }
        },
        "pi": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "tools": { "type": "array", "items": { "type": "string" } },
            "observedTools": { "type": "array", "items": { "type": "string" } },
            "skillPaths": { "type": "array", "items": { "type": "string" } },
            "workerArgs": { "type": "array", "items": { "type": "string" } },
            "workerExtensions": { "type": "array", "items": { "type": "string" } },
            "mcp": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "allowToolCalls": { "type": "boolean" },
                "blockedToolPatterns": { "type": "array", "items": { "type": "string" } }
              }
            },
            "shell": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "disallowProjectToolFallback": { "type": "boolean" },
                "blockedCommandPatterns": { "type": "array", "items": { "type": "string" } }
              }
            }
          }
        },
        "eventStore": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "dir": { "type": "string" },
            "name": { "type": "string" },
            "fileName": { "type": "string" }
          }
        },
        "contextRestartRequirements": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "rereadFiles": { "type": "array", "items": { "type": "string" } },
            "requireEvidence": { "type": "boolean" }
          }
        },
        "traceability": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "requirePlanToBead": { "type": "boolean" },
            "requireBeadToPlan": { "type": "boolean" },
            "evidenceStore": { "type": "string" }
          }
        },
        "reviewArtifacts": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "shipPostReview": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "state": { "type": "string" },
                "store": { "type": "string" },
                "eventType": { "type": "string" },
                "required": { "type": "boolean" }
              }
            }
          }
        },
        "transactionalState": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "requireReadSet": { "type": "boolean" },
            "requireWriteSet": { "type": "boolean" },
            "autoRestoreUnapprovedPaths": {
              "type": "array",
              "items": { "type": "string" }
            },
            "requireAssumptions": { "type": "boolean" },
            "requireVersionDependencies": { "type": "boolean" },
            "requireVerifierObligations": { "type": "boolean" },
            "requireConflictPolicy": { "type": "boolean" },
            "evidenceStore": { "type": "string" }
          }
        },
        "artifacts": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "baseDir": { "type": "string" },
            "templates": {
              "type": "object",
              "description": "Artifact-type registry. Each entry is a path template (string shorthand) or a rich declaration object. Object form lets an extension declare a harness-generated, writable system artifact.",
              "additionalProperties": {
                "oneOf": [
                  { "type": "string" },
                  {
                    "type": "object",
                    "additionalProperties": false,
                    "required": ["path"],
                    "properties": {
                      "path": { "type": "string", "description": "Path template (supports {{beadId}}, {{stateId}}, {{baseDir}}, {{projectRoot}}, {{worktreePath}})." },
                      "scope": { "type": "string", "enum": ["project", "worktree"], "description": "Root the template resolves against when relative. Defaults to project." },
                      "writable": { "type": "boolean", "description": "Permit the teammate to write this artifact's exact resolved path outside the plan write set." },
                      "ensureDir": { "type": "boolean", "description": "Harness ensures the artifact's parent directory exists (mkdir -p)." }
                    }
                  }
                ]
              }
            }
          }
        },
        "roots": {
          "type": "object",
          "description": "Named path roots resolved at runtime and injected as {{roots.NAME}} template variables into tool env, prompt variables, and path normalization virtualRoots. Values are absolute paths or paths relative to projectRoot. Keys are generic identifiers — project-specific names stay in project config, not harness defaults.",
          "additionalProperties": { "type": "string" }
        },
        "toolDefaults": {
          "$ref": "#/definitions/toolProfileShape",
          "description": "Global defaults applied to every command tool before per-tool or per-profile values. Per-tool fields always win over toolDefaults."
        },
        "toolProfiles": {
          "type": "object",
          "description": "Named reusable partial command-tool configuration blocks. A command tool may reference one profile by name via its 'profile' field; the profile's fields are applied after toolDefaults and before per-tool fields.",
          "additionalProperties": { "$ref": "#/definitions/toolProfileShape" }
        },
        "tsProjectToolDefaults": {
          "type": "object",
          "additionalProperties": false,
          "description": "Harness-wide defaults for tsProjectTool shorthand tools. scriptDir is the base directory (relative to projectRoot) used to resolve the default script path: <scriptDir>/<toolName>.ts. Defaults to .pi/project-tools.",
          "properties": {
            "scriptDir": {
              "type": "string",
              "description": "Base directory for default TS project-tool scripts. Relative to projectRoot. Defaults to .pi/project-tools."
            },
            "argsMode": { "type": "string", "enum": ["replace", "append"], "description": "Default argsMode for tsProjectTool tools. Defaults to append." },
            "allowArgs": { "type": "boolean", "description": "Default allowArgs for tsProjectTool tools. Defaults to true." },
            "cwd": { "type": "string" },
            "timeoutMs": { "type": "integer", "minimum": 1 },
            "wrapperTimeoutMs": { "type": "integer", "minimum": 1 }
          }
        },
        "worktreePolicy": {
          "type": "object",
          "additionalProperties": false,
          "description": "Harness-wide worktree allocation policy. Controls which states receive an isolated git worktree before the teammate is spawned. When absent, defaults to { default: 'always' }, preserving pre-existing behavior. Per-state provisionWorktree overrides this policy for individual states.",
          "properties": {
            "default": {
              "type": "string",
              "enum": ["always", "never"],
              "description": "Default provisioning mode for all states without an explicit provisionWorktree override. 'always' provisions a worktree for every state (default); 'never' runs all states at the project root unless overridden per-state."
            }
          }
        },
        "defaultActionContextMode": { "type": "string", "enum": ["same", "oneShot", "subagent"] },
        "defaultModel": { "type": "string" },
        "defaultProvider": { "type": "string" },
        "modelProviders": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "required": ["provider", "model"],
            "additionalProperties": false,
            "properties": {
              "provider": { "type": "string" },
              "model": { "type": "string" },
              "thinking": { "type": "string", "enum": ["off", "minimal", "low", "medium", "high", "xhigh"] }
            }
          }
        },
        "cycleCap": { "type": "integer", "minimum": 1, "description": "Maximum consecutive self-loop cycles before a blocked bead is escalated to the Team Lead." },
        "stateContextRotThreshold": { "type": "integer", "minimum": 1 },
        "harnessContextRotThreshold": { "type": "integer", "minimum": 1 },
        "observability": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "dir": { "type": "string" },
            "fileName": { "type": "string" },
            "retentionDays": { "type": "integer", "minimum": 1 },
            "collector": {
              "type": "object",
              "required": ["endpoint"],
              "additionalProperties": false,
              "properties": {
                "endpoint": { "type": "string" },
                "headers": {
                  "type": "object",
                  "additionalProperties": { "type": "string" }
                },
                "timeoutMs": { "type": "integer", "minimum": 1 }
              }
            }
          }
        }
      }
    },
    "scheduler": {
      "type": "object",
      "required": ["weights"],
      "properties": {
        "weights": {
          "type": "object",
          "required": ["waitTime", "executionTime", "progress", "penalty"],
          "properties": {
            "waitTime": { "type": "number" },
            "executionTime": { "type": "number" },
            "progress": { "type": "number" },
            "penalty": { "type": "number" }
          }
        }
      }
    },
    "retention": {
      "type": "object",
      "additionalProperties": false,
      "description": "Retention policy for harness-owned log/.tmp/.trash areas and event-JSONL compaction.",
      "properties": {
        "maxAgeMs": {
          "type": "integer",
          "minimum": 1,
          "description": "Maximum age in milliseconds for harness-owned log/.tmp/.trash entries. Defaults to 2 days."
        },
        "compactionEnabled": {
          "type": "boolean",
          "description": "Whether event-JSONL compaction is enabled. Defaults to false (safe default)."
        },
        "compactionWindowMs": {
          "type": "integer",
          "minimum": 1,
          "description": "Age in ms after which non-replay-critical events may be compacted. Defaults to 7 days."
        },
        "diskHealthWarnBytes": {
          "type": "integer",
          "minimum": 1,
          "description": "Bytes threshold for emitting a RETENTION_DISK_HEALTH event. Defaults to 50 MiB."
        }
      }
    },
    "tools": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "type": "object",
            "required": ["name", "type", "command"],
            "additionalProperties": false,
            "properties": {
              "name": { "type": "string", "pattern": "^[A-Za-z0-9_]+$" },
              "description": { "type": "string" },
              "usageNotes": { "type": "array", "items": { "type": "string" } },
              "failureLimit": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "maxFailuresPerState": { "type": "integer", "minimum": 1 },
                  "suggestedOutcome": { "type": "string" },
                  "suggestedOutcomeByState": {
                    "type": "object",
                    "additionalProperties": { "type": "string" }
                  },
                  "suggestedOutcomeByAction": {
                    "type": "object",
                    "additionalProperties": { "type": "string" }
                  },
                  "message": { "type": "string" },
                  "terminal": { "type": "boolean" }
                }
              },
              "type": { "const": "command" },
              "profile": { "type": "string", "description": "Name of a settings.toolProfiles entry whose fields are applied as defaults for this tool (after toolDefaults, before per-tool fields)." },
              "command": { "type": "string" },
              "defaultArgs": { "type": "array", "items": { "type": "string" } },
              "argsMode": { "type": "string", "enum": ["replace", "append"] },
              "allowArgs": { "type": "boolean" },
              "argumentPathScope": {
                "type": "object",
                "additionalProperties": false,
	                "properties": {
	                  "root": { "type": "string" },
	                  "rootKind": { "type": "string", "description": "Built-in values: worktree, project, framework, workspace. Any key from settings.roots is also valid and resolves to the configured named root." },
	                  "workspaceRoot": { "type": "string" },
	                  "virtualRoots": { "type": "array", "items": { "type": "string" } },
	                  "mustStayInsideRoot": { "type": "boolean" },
	                  "positionals": { "type": "boolean" },
                  "flags": { "type": "array", "items": { "type": "string" } }
                }
              },
              "cwd": { "type": "string" },
              "allowCwdOverride": { "type": "boolean" },
              "timeoutMs": { "type": "integer", "minimum": 1 },
              "wrapperTimeoutMs": { "type": "integer", "minimum": 1 },
              "acceptMaxBuffer": { "type": "boolean" },
              "successExitCodes": {
                "type": "array",
                "items": { "type": "integer", "minimum": 0 },
                "minItems": 1,
                "uniqueItems": true
              },
              "optional": { "type": "boolean" },
              "validationRules": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["tool", "condition"],
                  "additionalProperties": false,
                  "properties": {
                    "tool": { "type": "string" },
                    "condition": { "type": "string", "enum": ["called", "passed", "succeeded"] },
                    "message": { "type": "string" }
                  }
                }
              },
              "env": {
                "type": "object",
                "additionalProperties": { "type": "string" }
              }
            }
          },
          {
            "type": "object",
            "required": ["name", "type", "server"],
            "additionalProperties": false,
            "properties": {
              "name": { "type": "string", "pattern": "^[A-Za-z0-9_]+$" },
              "description": { "type": "string" },
              "usageNotes": { "type": "array", "items": { "type": "string" } },
              "failureLimit": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "maxFailuresPerState": { "type": "integer", "minimum": 1 },
                  "suggestedOutcome": { "type": "string" },
                  "suggestedOutcomeByState": {
                    "type": "object",
                    "additionalProperties": { "type": "string" }
                  },
                  "suggestedOutcomeByAction": {
                    "type": "object",
                    "additionalProperties": { "type": "string" }
                  },
                  "message": { "type": "string" },
                  "terminal": { "type": "boolean" }
                }
              },
              "type": { "const": "mcp" },
              "server": { "type": "string" },
              "configPath": { "type": "string" },
              "serialize": { "type": "boolean", "description": "Serialize calls to this MCP tool across teammates via a cross-process lock (for stateful/non-concurrent-safe MCP servers)." },
              "timeoutMs": { "type": "integer", "minimum": 1 },
              "wrapperTimeoutMs": { "type": "integer", "minimum": 1 },
              "argumentDefaults": {
                "type": "object",
                "additionalProperties": {
                  "type": "object",
                  "additionalProperties": true
                }
              },
              "argumentAllowlist": {
                "type": "object",
                "additionalProperties": {
                  "type": "array",
                  "items": { "type": "string" }
                }
              },
              "pathArguments": {
                "type": "object",
                "additionalProperties": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "object",
                    "additionalProperties": false,
	                    "properties": {
	                      "root": { "type": "string" },
	                      "rootKind": { "type": "string", "description": "Built-in values: worktree, project, framework, workspace. Any key from settings.roots is also valid and resolves to the configured named root." },
	                      "workspaceRoot": { "type": "string" },
	                      "virtualRoots": { "type": "array", "items": { "type": "string" } },
	                      "mustStayInsideRoot": { "type": "boolean" }
	                    }
                  }
                }
              },
              "operations": {
                "oneOf": [
                  { "type": "array", "items": { "type": "string" } },
                  {
                    "type": "object",
                    "additionalProperties": { "type": "string" }
                  }
                ]
              },
              "optional": { "type": "boolean" },
              "validationRules": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["tool", "condition"],
                  "additionalProperties": false,
                  "properties": {
                    "tool": { "type": "string" },
                    "condition": { "type": "string", "enum": ["called", "passed", "succeeded"] },
                    "message": { "type": "string" }
                  }
                }
              }
            }
          },
          {
            "type": "object",
            "required": ["name", "type"],
            "additionalProperties": false,
            "properties": {
              "name": { "type": "string", "pattern": "^[A-Za-z0-9_]+$" },
              "description": { "type": "string" },
              "usageNotes": { "type": "array", "items": { "type": "string" } },
              "failureLimit": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "maxFailuresPerState": { "type": "integer", "minimum": 1 },
                  "suggestedOutcome": { "type": "string" },
                  "suggestedOutcomeByState": {
                    "type": "object",
                    "additionalProperties": { "type": "string" }
                  },
                  "suggestedOutcomeByAction": {
                    "type": "object",
                    "additionalProperties": { "type": "string" }
                  },
                  "message": { "type": "string" },
                  "terminal": { "type": "boolean" }
                }
              },
              "type": { "const": "extension" },
              "optional": { "type": "boolean" },
              "validationRules": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["tool", "condition"],
                  "additionalProperties": false,
                  "properties": {
                    "tool": { "type": "string" },
                    "condition": { "type": "string", "enum": ["called", "passed", "succeeded"] },
                    "message": { "type": "string" }
                  }
                }
              }
            }
          },
          {
            "type": "object",
            "required": ["name", "type"],
            "additionalProperties": false,
            "description": "TypeScript project-tool shorthand. Expands to type: command with command: node, --experimental-strip-types, and the resolved script path before schema validation. argsMode defaults to append and allowArgs defaults to true unless explicitly overridden.",
            "properties": {
              "name": { "type": "string", "pattern": "^[A-Za-z0-9_]+$" },
              "description": { "type": "string" },
              "usageNotes": { "type": "array", "items": { "type": "string" } },
              "type": { "const": "tsProjectTool" },
              "scriptPath": {
                "type": "string",
                "description": "Path to the TypeScript script. Absolute or relative to projectRoot. Defaults to <settings.tsProjectToolDefaults.scriptDir>/<toolName>.ts (or .pi/project-tools/<toolName>.ts if not configured). Supports {{projectRoot}} template variable."
              },
              "profile": { "type": "string", "description": "Name of a settings.toolProfiles entry applied after tsProjectTool defaults and before per-tool fields." },
              "defaultArgs": { "type": "array", "items": { "type": "string" }, "description": "Additional args appended after the script path. The node + --experimental-strip-types + scriptPath prefix is always prepended." },
              "argsMode": { "type": "string", "enum": ["replace", "append"] },
              "allowArgs": { "type": "boolean" },
              "argumentPathScope": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "root": { "type": "string" },
                  "rootKind": { "type": "string" },
                  "workspaceRoot": { "type": "string" },
                  "virtualRoots": { "type": "array", "items": { "type": "string" } },
                  "mustStayInsideRoot": { "type": "boolean" },
                  "positionals": { "type": "boolean" },
                  "flags": { "type": "array", "items": { "type": "string" } }
                }
              },
              "cwd": { "type": "string" },
              "allowCwdOverride": { "type": "boolean" },
              "timeoutMs": { "type": "integer", "minimum": 1 },
              "wrapperTimeoutMs": { "type": "integer", "minimum": 1 },
              "acceptMaxBuffer": { "type": "boolean" },
              "successExitCodes": {
                "type": "array",
                "items": { "type": "integer", "minimum": 0 },
                "minItems": 1,
                "uniqueItems": true
              },
              "optional": { "type": "boolean" },
              "failureLimit": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "maxFailuresPerState": { "type": "integer", "minimum": 1 },
                  "suggestedOutcome": { "type": "string" },
                  "suggestedOutcomeByState": {
                    "type": "object",
                    "additionalProperties": { "type": "string" }
                  },
                  "suggestedOutcomeByAction": {
                    "type": "object",
                    "additionalProperties": { "type": "string" }
                  },
                  "message": { "type": "string" },
                  "terminal": { "type": "boolean" }
                }
              },
              "validationRules": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["tool", "condition"],
                  "additionalProperties": false,
                  "properties": {
                    "tool": { "type": "string" },
                    "condition": { "type": "string", "enum": ["called", "passed", "succeeded"] },
                    "message": { "type": "string" }
                  }
                }
              },
              "env": {
                "type": "object",
                "additionalProperties": { "type": "string" }
              }
            }
          }
        ]
      }
    },
    "statechart": {
      "type": "object",
      "required": ["terminalStates"],
      "additionalProperties": false,
      "description": "Statechart vocabulary configuration. All fields except terminalStates have defaults that reproduce the original SUCCESS/FAILURE/BLOCKED/completed literals.",
      "properties": {
        "initialState": {
          "type": "string",
          "description": "Override for the initial state (mirrors settings.startState; settings wins)."
        },
        "terminalStates": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1,
          "description": "State IDs that are terminal (workflow is done when reached). Defaults to ['completed'] when the block is absent."
        },
        "advanceOutcomes": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Outcome strings that trigger forward state advancement. Defaults to ['SUCCESS']."
        },
        "failedOutcomes": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Outcome strings that map to STATE_FAILED. Defaults to ['FAILURE']."
        },
        "blockedOutcomes": {
          "type": "array",
