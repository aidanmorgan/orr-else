          "llmProvider": { "type": "string" },
          "model": { "type": "string" },
          "thinking": { "type": "string", "enum": ["off", "minimal", "low", "medium", "high", "xhigh"] },
          "contextRotThreshold": { "type": "integer", "minimum": 1 },
          "provisionWorktree": {
            "type": "boolean",
            "description": "Whether to provision an isolated git worktree for this state. When true, the Supervisor creates a per-bead worktree before spawning the teammate. When false, the teammate runs at the project root. When absent, falls back to settings.worktreePolicy.default ('always' if not set)."
          },
          "handoverTemplate": { "type": "string" },
          "qualityCheckCommand": { "type": "string" },
          "checklist": {
            "oneOf": [
              { "type": "string" },
              {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["text"],
                  "properties": {
                    "text": { "type": "string" },
