                        "properties": {
                          "text": { "type": "string" },
                          "mandatory": { "type": "boolean" },
                          "type": { "type": "string", "enum": ["manual", "tool", "script"] },
                          "tool": { "type": "string" },
                          "script": { "type": "string" }
                        }
                      }
                    }
                  ]
                }
              }
            }
          },
          "transitions": {
            "type": "object",
            "properties": {
            },
            "additionalProperties": { "type": "string" }
          }
        }
      }
    }
